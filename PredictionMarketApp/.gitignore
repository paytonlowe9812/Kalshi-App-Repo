# SQLite stores API keys (PEM), key IDs, bots, rules, and logs -- do not commit or share
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db-journal

# Python virtual environment
.venv/

# Bytecode
__pycache__/
*.py[cod]
*$py.class

# Frontend
frontend/node_modules/

